<?xml version="1.0" encoding="utf-8"?>
<!-- Body of the Plan Detail dialog: list of exercises in the plan, plus actions. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="8dp">

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No exercises in this plan yet."
        android:textAlignment="center"
        android:textColor="@color/onSurfaceMuted"
        android:padding="16dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlanExercises"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="320dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnAddExerciseToPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Exercise"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnStartWorkout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Workout"
        android:layout_marginTop="12dp" />

</LinearLayout>
